{
  "name": "prediction-market-divergence",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "db:remote": "wrangler d1 execute prediction-market-divergence --remote --file=./migrations/0001_init.sql",
    "db:remote:kalshi": "wrangler d1 execute prediction-market-divergence --remote --file=./migrations/0002_kalshi_ingestion.sql",
    "test": "node --experimental-strip-types --test src/sources/kalshi.test.ts src/sources/kalshi-auth.test.ts src/kalshi-ingest.test.ts src/polymarket/*.test.ts",
    "db:remote:polymarket": "wrangler d1 execute prediction-market-divergence --remote --file=./migrations/0003_polymarket_ingestion.sql",
    "db:purge-history": "wrangler d1 execute prediction-market-divergence --remote --file=./migrations/0004_purge_d1_history.sql",
    "db:cleanup": "wrangler d1 execute prediction-market-divergence --remote --file=./migrations/0005_daily_cleanup.sql",
    "db:remote:tiered": "wrangler d1 execute prediction-market-divergence --remote --file=./migrations/0006_tiered_pipeline.sql",
    "research:daily": "cd research && python pm.py run-daily",
    "research:status": "cd research && python pm.py status",
    "r2:create-history": "wrangler r2 bucket create prediction-market-divergence-history",
    "polymarket": "node --experimental-strip-types scripts/polymarket-cli.ts",
    "deploy": "wrangler pages deploy public --project-name=prediction-market-divergence"
  },
  "dependencies": {
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260624.1",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.104.0",
    "ws": "^8.18.3"
  }
}