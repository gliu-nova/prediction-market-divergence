# Cloudflare (local wrangler deploy)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# Poll / engine
USE_MOCK=false
MIN_DIVERGENCE_PCT_POINTS=5
MIN_VOLUME=1000
LOOKBACK_DAYS=30
OPPORTUNITY_MAX_AGE_HOURS=24
OBSERVATION_RETENTION_DAYS=30

# Polymarket ingestion (all optional)
# POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
# POLYMARKET_CLOB_URL=https://clob.polymarket.com
# POLYMARKET_CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
# POLYMARKET_DATA_API_URL=https://data-api.polymarket.com
# POLYMARKET_MAX_MARKETS=100
# POLYMARKET_MAX_GAMMA_PAGES=2
# POLYMARKET_CLOB_ENRICH_MAX=100
# POLYMARKET_RATE_LIMIT_MS=100
# POLYGON_RPC_URL=