# GitHub Actions deploy secrets (DO NOT commit real values here):
# Set in GitHub → Settings → Secrets and variables → Actions:
#   CLOUDFLARE_ACCOUNT_ID
#   CLOUDFLARE_API_TOKEN
# For local wrangler deploy: export those env vars in your shell, or use `npx wrangler login`.

# Optional overrides (config.yaml is primary)
PMD_HOST=0.0.0.0
PMD_PORT=8080
PMD_USE_MOCK=0
PMD_STORAGE_MODE=memory
PMD_DB_PATH=data/prediction_markets.db
PMD_POLL_INTERVAL_SECONDS=300
PMD_MIN_DIVERGENCE_PCT_POINTS=5.0
PMD_MIN_VOLUME=1000.0
PMD_OPPORTUNITY_MAX_AGE_HOURS=24